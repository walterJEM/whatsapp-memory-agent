# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/memory_agent

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── WhatsApp (choose one: Twilio or 360dialog) ───────────────────────────────
# Twilio
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 360dialog
DIALOG360_API_KEY=xxxx
DIALOG360_PHONE_NUMBER_ID=xxxx

# ─── App ──────────────────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=my_secure_verify_token
ENVIRONMENT=development  # development | production
LOG_LEVEL=INFO

# ─── Free Plan Limits ─────────────────────────────────────────────────────────
FREE_PLAN_MONTHLY_NOTES=50
FREE_PLAN_REMINDERS=3
FREE_PLAN_RECEIPT_SCANS=5
